# VAPI
VAPI_WEBHOOK_SECRET=your-webhook-secret-here
VAPI_PUBLIC_KEY=your-vapi-public-key-here
VAPI_ASSISTANT_ID=your-vapi-assistant-id-here

# Google Sheets
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here
# Paste full service account JSON as one line
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Airtable
AIRTABLE_API_KEY=your-airtable-api-key-here
AIRTABLE_BASE_ID=your-airtable-base-id-here

# OpenAI (for post-call summaries)
OPENAI_API_KEY=your-openai-api-key-here

# Dashboard access control
# Set a strong random token. Operators enter this once in the browser login prompt.
# Leave empty to disable auth (dev only — never in production).
DASHBOARD_SECRET=your-dashboard-secret-here

# Server
PORT=3000
